{
  "name": "cat-inspect-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":   "nodemon --experimental-vm-modules server.js",
    "start": "node server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:studio":  "npx prisma studio"
  },
  "dependencies": {
    "express":          "^4.19.2",
    "cors":             "^2.8.5",
    "helmet":           "^7.1.0",
    "morgan":           "^1.10.0",
    "dotenv":           "^16.4.5",
    "socket.io":        "^4.7.5",
    "jsonwebtoken":     "^9.0.2",
    "bcryptjs":         "^2.4.3",
    "multer":           "^1.4.5-lts.1",
    "openai":           "^4.52.2",
    "@google/generative-ai": "^0.15.0",
    "@anthropic-ai/sdk": "^0.26.0",
    "google-auth-library": "^9.13.0",
    "@google-cloud/storage": "^7.11.3",
    "@prisma/client":   "^5.16.1",
    "pdfkit":           "^0.15.0",
    "zod":              "^3.23.8"
  },
  "devDependencies": {
    "nodemon":    "^3.1.4",
    "prisma":     "^5.16.1"
  }
}


// ═══════════════════════════════════════════════════════════
//  cat-inspect-app/app.config.js  (Expo config)
// ═══════════════════════════════════════════════════════════
module.exports = {
  expo: {
    name:   "CAT Inspect AI",
    slug:   "cat-inspect-ai",
    version:"1.0.0",
    orientation: "portrait",
    icon:   "./assets/icon.png",
    scheme: "catinspect",
    userInterfaceStyle: "dark",
    splash: { image: "./assets/splash.png", resizeMode: "contain", backgroundColor: "#080808" },
    ios: {
      supportsTablet: true,
      bundleIdentifier: "com.caterpillar.inspectai",
      infoPlist: {
        NSCameraUsageDescription: "Required for live equipment inspection",
        NSMicrophoneUsageDescription: "Required for voice-controlled inspection",
        NSPhotoLibraryUsageDescription: "Required to upload inspection media",
      },
    },
    android: {
      adaptiveIcon: { foregroundImage: "./assets/adaptive-icon.png", backgroundColor: "#080808" },
      package: "com.caterpillar.inspectai",
      permissions: ["CAMERA", "RECORD_AUDIO", "READ_EXTERNAL_STORAGE"],
    },
    plugins: [
      "expo-router",
      ["expo-camera",      { cameraPermission: "Allow CAT Inspect to use the camera" }],
      ["expo-av",          { microphonePermission: "Allow CAT Inspect to use the microphone" }],
      ["expo-document-picker"],
      ["@react-native-google-signin/google-signin"],
    ],
    extra: {
      eas: { projectId: "your-eas-project-id" }
    },
  },
};
